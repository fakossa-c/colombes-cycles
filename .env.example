# Colombes Cycles — Variables d'environnement
# Copier ce fichier vers .env.local et remplir les valeurs
#
# Convention :
#   - Variables côté serveur uniquement → pas de préfixe
#   - Variables accessibles côté client (navigateur) → préfixer avec NEXT_PUBLIC_

# Clé API CRM (projet)
CRM_PROJECT_API_KEY=your_key_here
